# Переменные Traefik
TRAEFIK_IMAGE_TAG=traefik:3.2
# Уровень логирования (DEBUG, INFO, WARN, ERROR)
TRAEFIK_LOG_LEVEL=WARN
# Email для уведомлений Let's Encrypt о продлении сертификатов
TRAEFIK_ACME_EMAIL=admin@example.com
# Имя хоста для доступа к панели Traefik и настройки правил для домена
TRAEFIK_HOSTNAME=traefik.wiki.domain.com
# Базовая аутентификация панели Traefik
# Логин: traefikadmin
# Пароли должны быть в формате MD5, SHA1 или BCrypt https://www.web2generators.com/apache-tools/htpasswd-generator
TRAEFIK_BASIC_AUTH=traefikadmin:$$2y$$10$$sMzJfirKC75x/hVpiINeZOiSm.Jkity9cn4KwNkRvO7hSQVFc5FLO

# Переменные XWiki
XWIKI_POSTGRES_IMAGE_TAG=postgres:15
# Собирается из docker/backups (FROM XWIKI_POSTGRES_IMAGE_TAG + Python/boto3)
XWIKI_BACKUP_IMAGE_TAG=xwiki-backup:15
XWIKI_IMAGE_TAG=xwiki:15.7.0-postgres-tomcat
XWIKI_DB_NAME=xwiki
XWIKI_DB_USER=xwikidbuser
XWIKI_DB_PASSWORD=password1234
XWIKI_HOSTNAME=wiki.domain.com

# Переменные резервного копирования (единый архив: БД + данные приложения)
BACKUP_INIT_SLEEP=30m
BACKUP_INTERVAL=24h
BACKUP_PRUNE_DAYS=7
XWIKI_BACKUPS_PATH=/srv/xwiki/backups
XWIKI_BACKUP_NAME=xwiki-backup
DATA_PATH=/usr/local/xwiki

# S3 (опционально; без S3_BUCKET_NAME загрузка пропускается)
# S3_BUCKET_NAME=my-bucket
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=eu-central-1
# S3_ENDPOINT_URL=
# S3_PREFIX=xwiki/backups
